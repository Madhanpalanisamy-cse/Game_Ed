<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>StudyQuest | Gamified Learning</title>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&family=Roboto:wght@300;400;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #00f2ff;
            --secondary: #7000ff;
            --bg: #0b0e14;
            --card-bg: rgba(255, 255, 255, 0.05);
            --text: #e0e0e0;
        }

        body {
            margin: 0;
            padding: 0;
            font-family: 'Roboto', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow-x: hidden;
        }

        .container {
            width: 90%;
            max-width: 800px;
            padding: 40px;
            background: var(--card-bg);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 24px;
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
        }

        header {
            text-align: center;
            margin-bottom: 40px;
        }

        h1 {
            font-family: 'Orbitron', sans-serif;
            font-size: 2.5rem;
            margin: 0;
            background: linear-gradient(90deg, var(--primary), var(--secondary));
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .stats {
            display: flex;
            justify-content: space-around;
            margin-bottom: 30px;
            padding: 20px;
            background: rgba(0, 0, 0, 0.2);
            border-radius: 16px;
        }

        .stat-item {
            text-align: center;
        }

        .stat-value {
            font-family: 'Orbitron', sans-serif;
            font-size: 1.5rem;
            color: var(--primary);
        }

        .stat-label {
            font-size: 0.8rem;
            text-transform: uppercase;
            opacity: 0.7;
        }

        .progress-container {
            width: 100%;
            height: 12px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 6px;
            margin-bottom: 40px;
            overflow: hidden;
        }

        .progress-bar {
            height: 100%;
            background: linear-gradient(90deg, var(--primary), var(--secondary));
            width: 0%;
            transition: width 0.5s ease-out;
            box-shadow: 0 0 10px var(--primary);
        }

        .task-list {
            list-style: none;
            padding: 0;
        }

        .task-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 20px;
            background: rgba(255, 255, 255, 0.03);
            border-radius: 12px;
            margin-bottom: 12px;
            border: 1px solid transparent;
            transition: 0.3s;
        }

        .task-item:hover {
            border-color: var(--primary);
            background: rgba(255, 255, 255, 0.05);
        }

        .task-item.completed {
            opacity: 0.5;
            text-decoration: line-through;
        }

        .task-title {
            font-weight: 500;
        }

        .xp-reward {
            font-size: 0.8rem;
            color: var(--primary);
            margin-left: 10px;
        }

        button {
            padding: 8px 16px;
            background: var(--primary);
            border: none;
            border-radius: 8px;
            color: #000;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
        }

        button:hover {
            filter: brightness(1.2);
            box-shadow: 0 0 15px var(--primary);
        }

        button:disabled {
            background: #555;
            cursor: not-allowed;
            box-shadow: none;
        }

        .notification {
            position: fixed;
            top: 20px;
            right: 20px;
            background: var(--secondary);
            color: white;
            padding: 15px 25px;
            border-radius: 10px;
            font-weight: bold;
            display: none;
            animation: slideIn 0.5s ease-out;
        }

        @keyframes slideIn {
            from { transform: translateX(100%); }
            to { transform: translateX(0); }
        }
    </style>
</head>
<body>

<div class="notification" id="notif">LEVEL UP! 🚀</div>

<div class="container">
    <header>
        <h1>STUDYQUEST</h1>
        <p>Your Journey to Knowledge</p>
    </header>

    <div class="stats">
        <div class="stat-item">
            <div class="stat-label">Level</div>
            <div class="stat-value" id="level">{{ student.level }}</div>
        </div>
        <div class="stat-item">
            <div class="stat-label">XP</div>
            <div class="stat-value"><span id="xp">{{ student.xp }}</span> / <span id="xp_needed">{{ student.xp_to_next_level }}</span></div>
        </div>
    </div>

    <div class="progress-container">
        <div class="progress-bar" id="pb" style="width: {{ (student.xp / student.xp_to_next_level) * 100 }}%;"></div>
    </div>

    <h2 style="font-family: 'Orbitron', sans-serif; font-size: 1.2rem; border-left: 4px solid var(--primary); padding-left: 10px; margin: 30px 0 20px 0;">Available Practice Quests</h2>
    <div class="question-list">
        {% for q in questions %}
        <div class="task-item {{ 'completed' if q.solved else '' }}" id="question-{{ q.id }}" style="flex-direction: column; align-items: flex-start; gap: 10px;">
            <div style="width: 100%; display: flex; justify-content: space-between;">
                <span class="stat-label" style="background: var(--secondary); padding: 2px 8px; border-radius: 4px; color: white;">{{ q.type }}</span>
                <span class="xp-reward">+{{ q.xp_reward }} XP</span>
            </div>
            <div class="task-title">{{ q.content }}</div>
            <div style="width: 100%; display: flex; gap: 10px; margin-top: 10px;">
                <input type="text" id="answer-{{ q.id }}" placeholder="Your answer..." style="flex: 1; padding: 8px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1); background: rgba(0,0,0,0.3); color: white;" {{ 'disabled' if q.solved else '' }}>
                <button onclick="solveQuestion({{ q.id }})" {{ 'disabled' if q.solved else '' }}>Submit</button>
            </div>
            <div id="feedback-{{ q.id }}" style="font-size: 0.8rem; margin-top: 5px;"></div>
        </div>
        {% endfor %}
    </div>
</div>

<script>
    function completeTask(taskId) {
        fetch(`/complete/${taskId}`, { method: 'POST' })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    const student = data.student;
                    document.getElementById('level').innerText = student.level;
                    document.getElementById('xp').innerText = student.xp;
                    document.getElementById('xp_needed').innerText = student.xp_to_next_level;
                    
                    const progress = (student.xp / student.xp_to_next_level) * 100;
                    document.getElementById('pb').style.width = progress + '%';

                    const taskEl = document.getElementById(`task-${taskId}`);
                    taskEl.classList.add('completed');
                    taskEl.querySelector('button').disabled = true;

                    if (data.level_up) {
                        showNotification();
                    }
                }
            });
    }

    function solveQuestion(qId) {
        const answer = document.getElementById(`answer-${qId}`).value;
        const feedback = document.getElementById(`feedback-${qId}`);
        
        fetch(`/solve/${qId}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ answer: answer })
        })
            .then(res => res.json())
            .then(data => {
                feedback.innerText = data.message;
                feedback.style.color = data.success ? 'var(--primary)' : '#ff4b4b';

                if (data.success) {
                    const student = data.student;
                    document.getElementById('level').innerText = student.level;
                    document.getElementById('xp').innerText = student.xp;
                    document.getElementById('xp_needed').innerText = student.xp_to_next_level;
                    
                    const progress = (student.xp / student.xp_to_next_level) * 100;
                    document.getElementById('pb').style.width = progress + '%';

                    const qEl = document.getElementById(`question-${qId}`);
                    qEl.classList.add('completed');
                    qEl.querySelector('button').disabled = true;
                    qEl.querySelector('input').disabled = true;

                    if (data.level_up) {
                        showNotification();
                    }
                }
            });
    }

    function showNotification() {
        const notif = document.getElementById('notif');
        notif.style.display = 'block';
        setTimeout(() => {
            notif.style.display = 'none';
        }, 3000);
    }
</script>

</body>
</html>
